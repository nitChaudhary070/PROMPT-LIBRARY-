rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "chaudharynitinbhai575@gmail.com" && request.auth.token.email_verified == true));
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['email', 'role', 'createdAt']) &&
             isValidString('email', 3, 100) &&
             request.resource.data.role in ['user', 'admin'];
    }

    function isValidPrompt() {
      return hasOnlyAllowedFields(['title', 'prompt_text', 'image_url', 'category', 'tags', 'upvote_count', 'views', 'copies', 'createdAt']) &&
             isValidString('title', 1, 200) &&
             isValidString('prompt_text', 1, 5000) &&
             isValidString('category', 1, 100) &&
             request.resource.data.image_url is string &&
             request.resource.data.tags is list &&
             request.resource.data.upvote_count is number &&
             request.resource.data.views is number &&
             request.resource.data.copies is number;
    }

    function isValidFavorite() {
      return hasOnlyAllowedFields(['userId', 'promptId', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('promptId', 1, 100);
    }

    function isValidUpvote() {
      return hasOnlyAllowedFields(['userId', 'promptId', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('promptId', 1, 100);
    }

    function isValidCollection() {
      return hasOnlyAllowedFields(['userId', 'name', 'createdAt']) &&
             request.resource.data.userId == request.auth.uid &&
             isValidString('name', 1, 100);
    }

    function isValidCollectionPrompt() {
      return hasOnlyAllowedFields(['collectionId', 'promptId', 'createdAt']) &&
             isValidString('collectionId', 1, 100) &&
             isValidString('promptId', 1, 100);
    }

    function isValidSetting() {
      return hasOnlyAllowedFields(['value']) &&
             isValidString('value', 1, 100);
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser() && ((isOwner(userId) && request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    match /prompts/{promptId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidPrompt();
      allow update: if (isAdmin() && isValidPrompt()) ||
                    // Allow users to upvote (only changing upvote_count by 1)
                    (isAuthenticated() &&
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvote_count']) &&
                     math.abs(request.resource.data.upvote_count - resource.data.upvote_count) == 1) ||
                    // Allow users to view and copy (only changing views or copies by 1)
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                     request.resource.data.views == resource.data.views + 1) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['copies']) &&
                     request.resource.data.copies == resource.data.copies + 1);
      allow delete: if isAdmin();
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidFavorite();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /upvotes/{upvoteId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidUpvote();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /collections/{collectionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidCollection();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidCollection();
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /collection_prompts/{collectionPromptId} {
      allow read: if isAuthenticated(); // Need to check if user owns the collection, but keeping simple for now
      allow create: if isAuthenticated() && isValidCollectionPrompt();
      allow delete: if isAuthenticated();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSetting();
    }
  }
}
